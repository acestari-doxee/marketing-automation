# LeadCleaner — environment variables template.
# Copy to `.env` and fill in your Apollo API key. NEVER commit .env.
#
# QUICK START:
#   1. cp .env.example .env
#   2. npm install
#   3. node server.js  (or double-click start.command on Mac)

# ---------- Core ----------
PORT=3000

# ---------- Apollo.io ----------
# Get your key at: https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=

APOLLO_MONTHLY_LIMIT=30020
